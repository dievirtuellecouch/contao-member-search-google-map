            } else { $heightCss = $hs; }
        }
    }
  ?>
  <div class="cm-map-wrap" style="height:<?= htmlspecialchars($heightCss, ENT_QUOTES, 'UTF-8') ?>">
    <div class="gm-placeholder" style="display:flex;align-items:center;justify-content:center;height:100%;text-align:center;padding:1rem;">
      <div>
        <?= $this->acceptanceText ?>
        <br>
        <a class="module-cookiebar-opener ccb-trigger" href="javascript:;" rel="noreferrer noopener">Cookies zurücksetzen</a>
      </div>
    </div>
    <div
      class="cm-map"
      id="<?= $mapId ?>"
      data-api-key="<?= htmlspecialchars((string)($this->googleApiKey ?? ''), ENT_QUOTES, 'UTF-8') ?>"
      data-markers='<?= $this->markersJson ?: '[]' ?>'
      data-center="<?= htmlspecialchars((string)($this->mapCenterEmpty ?: ''), ENT_QUOTES, 'UTF-8') ?>"
      data-zoom="<?= (int)($this->mapZoomEmpty ?: 6) ?>"
      style="height:100%; width:100%"
    ></div>
  </div>
<?php endif; ?>
