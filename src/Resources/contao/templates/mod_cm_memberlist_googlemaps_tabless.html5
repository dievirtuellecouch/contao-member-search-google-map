              $resolvedAction = $base . '/preview.php/' . ltrim($url, '/');
            }
          }
        }
      }
    } catch (\Throwable $e) {}
  ?>
  <form action="<?= $resolvedAction; ?>" method="get">
    <input type="hidden" name="cmf_submitted" value="1">
    <div class="formbody">
      <?php if ($this->fieldsearch && !$this->multifieldsearch): ?>
        <label for="ctrl_search_b" class="notinvisible"><?= $this->fields_label; ?></label>
        <select name="search" id="ctrl_search_b" class="select"><?= $this->search_fields ?? '' ?></select>
      <?php endif; ?>
      <?php if ($this->fieldsearch || $this->multifieldsearch): ?>
        <label for="ctrl_for_b" class="notinvisible"><?= $this->keywords_label; ?></label>
        <input type="text" name="for" id="ctrl_for_b" class="text" value="<?= $this->for ?? '' ?>">
      <?php endif; ?>
      <label for="plz_b" class="notinvisible">Postleitzahl</label>
      <input type="text" name="plz" id="plz_b" class="text" value="<?= $this->plz; ?>">
      <?php if (!empty($this->field_inputs)): ?>
        <div class="cm-field-inputs">
          <?= $this->field_inputs ?>
        </div>
      <?php endif; ?>
      <?php if (!empty($this->show_country)) : ?>
        <label for="cm_country_b"><?= $this->lbl_country; ?></label>
        <?= $this->visitorcountry; ?>
      <?php endif; ?>
      <?php if ($this->distanceform) : ?>
        <div class="cm-radius-row" style="display:flex;align-items:center;gap:.5rem;flex-wrap:nowrap;">
          <?php if ($this->distanceasdropdown) : ?>
            <label for="cm_max_dist_b" class="notinvisible"><?= $this->lbl_max_dist_drdn; ?></label>
            <select name="cm_max_dist" id="cm_max_dist_b" class="cm_max_dist_select"><?= $this->distvalues; ?></select>
          <?php else: ?>
            <label for="cm_max_dist_b" class="notinvisible"><?= $this->lbl_max_dist; ?></label>
            <input type="text" name="cm_max_dist" id="cm_max_dist_b" class="cm_max_dist" value="<?= $this->max_dist; ?>">
          <?php endif; ?>
          <span class="distitem"><?= $this->cm_distitem; ?></span>
        </div>
      <?php endif; ?>
      <?php if (!empty($this->show_address)) : ?>
        <label for="cm_location_b"><?= $this->lbl_location; ?></label>
        <input type="text" name="cm_location" id="cm_location_b" class="cm_location" value="<?= $this->visitorlocation ?>">
      <?php endif; ?>
      <input type="submit" class="submit" value="<?= $this->distsearch_label; ?>">
    </div>
  </form>
</div>
<?php endif; ?>
